# Copie este arquivo para .env e preencha os valores reais
# Em produção: DEBUG=False, gere um SECRET_KEY novo!
DEBUG=True

# Django — gere uma chave com:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-para-uma-chave-secreta

# Hosts
ALLOWED_HOSTS=ifmaker.cba.ifmt.edu.br,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://ifmaker.cba.ifmt.edu.br,http://127.0.0.1,http://localhost

# URL pública do sistema (sem barra no final) — usada em links de e-mail
SITE_URL=https://ifmaker.cba.ifmt.edu.br

# Banco de dados PostgreSQL (usado quando DEBUG=False)
DB_NAME=fablab_db
DB_USER=fablab_user
DB_PASSWORD=fablab_pass
DB_HOST=db
DB_PORT=5432

# E-mail (SMTP Gmail com App Password)
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=FabLab <fablab@example.com>

# Segurança — ative em produção após verificar que o Nginx passa X-Forwarded-Proto
SECURE_SSL_REDIRECT=False

# Analytics Umami — deixe em branco para desativar
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=

# CORS para o app Flutter (em produção, liste as origens explicitamente)
CORS_ALLOWED_ORIGINS=http://localhost:3000
